# ==============================================================================
# SaleOS Master Environment Variables — copy this file to .env and fill values
# Run scripts/generate_secrets.py to generate JWT_SECRET, X_SERVICE_TOKEN,
# ENCRYPTION_KEY, and WS_SECRET automatically.
# ==============================================================================

# App
APP_NAME=SaleOS
APP_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# JWT
JWT_SECRET=changeme_run_generate_secrets_script
JWT_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=postgresql+asyncpg://saleos_admin:saleos_dev_password@postgres:5432/saleos_db
POSTGRES_USER=saleos_admin
POSTGRES_PASSWORD=saleos_dev_password
POSTGRES_DB=saleos_db

# Redis — each service uses a dedicated DB index to prevent queue collisions
REDIS_URL=redis://redis:6379
REDIS_DB_CORE=0
REDIS_DB_TELEGRAM=1
REDIS_DB_TIKTOK=2
REDIS_DB_INSTAGRAM=3
REDIS_DB_FACEBOOK=4

# Security — generate with: python scripts/generate_secrets.py
X_SERVICE_TOKEN=changeme_run_generate_secrets_script
ENCRYPTION_KEY=changeme_run_generate_secrets_script

# AI — Primary: Gemini, Fallback: OpenAI
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# MinIO — self-hosted S3-compatible file storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=saleos_minio_admin
MINIO_SECRET_KEY=saleos_minio_dev_secret
MINIO_BUCKET_OCR=ocr-receipts
MINIO_BUCKET_MEDIA=merchant-media
MINIO_USE_SSL=false

# Microservice URLs (Core uses these to call individual services)
TELEGRAM_SERVICE_URL=http://saleos-telegram:8001
TIKTOK_SERVICE_URL=http://saleos-tiktok:8002
INSTAGRAM_SERVICE_URL=http://saleos-instagram:8003
FACEBOOK_SERVICE_URL=http://saleos-facebook:8004

# Telegram
# Local dev: use ngrok or similar to expose localhost to the internet for Telegram webhooks
# Production: https://api.yourdomain.com/api/v1/telegram/webhook
TELEGRAM_WEBHOOK_BASE_URL=http://localhost/api/v1/telegram/webhook

# OCR — external Ethiopian bank receipt verification team
# Fill in when the external team delivers the API credentials
EXTERNAL_ETHIOPIAN_BANK_OCR_API_URL=https://ocr.placeholder.com/api/v1/verify-receipt
EXTERNAL_ETHIOPIAN_BANK_OCR_API_TOKEN=placeholder

# Email (Mailgun transactional)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USERNAME=notifications@saleos.com
SMTP_PASSWORD=your_smtp_password

# WebSocket — generate with: python scripts/generate_secrets.py
WS_SECRET=changeme_run_generate_secrets_script
